{% do-not-edit-edn-comment %}
{:paths ["src"]
 :deps {org.clojure/clojure {:mvn/version "{‚óäanalyzer-clojure-mvn-version‚óä}"}}
 :aliases {:nREPL
           {:extra-deps
            {nrepl/nrepl {:mvn/version "{‚óänrepl-mvn-version‚óä}"}
             cider/piggieback {:mvn/version "{‚óäpiggieback-mvn-version‚óä}"}}
            :main-opts ["-m" "nrepl.cmdline"
                        "--interactive"]}
           :test
           {:jvm-opts ["-Dtyped.clojure.preserve-check-ns-after-opt-in=true"]
            :extra-paths ["test"]}
           :codox
           {:extra-deps {codox/codox {:mvn/version "{‚óäcodox-mvn-version‚óä}"}}
            :extra-paths ["script"]
            :main-opts ["-m" "gen-doc"]}

           :runner-cljs {:extra-deps {olical/cljs-test-runner {:mvn/version "3.7.0"}}
                         :main-opts ["-m" "cljs-test-runner.main"
                                     "-d" "test"
                                     "--out" "target/cljs-test-runner-out"]}

           :runner
           {:extra-deps {{‚óäcognitect-test-runner-coordinates‚óä}
                         {:git/url "{‚óäcognitect-test-runner-git-url‚óä}"
                          :git/sha "{‚óäcognitect-test-runner-sha‚óä}"}}
            :main-opts ["-m" "cognitect.test-runner"
                        "-r" ".*"
                        "-d" "test"]}}}
